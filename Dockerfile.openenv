# OpenEnv HTTP env server (not used by HF Streamlit Space).
# Build: docker build -f Dockerfile.openenv -t hr-openenv .
# Run:  docker run -p 7860:7860 hr-openenv
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 7860

CMD ["python", "-m", "openenv.core.env_server", "--host", "0.0.0.0", "--port", "7860"]
